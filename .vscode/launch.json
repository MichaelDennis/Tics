{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Tics (m32)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/Bin/${fileBasenameNoExtension}",
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "preLaunchTask": "Build Tics to Bin (m32)",
            "miDebuggerPath": "/usr/bin/gdb",
            "sourceFileMap": {
                "/home/mdm/projects/Tics": "${workspaceFolder}"
            }
        }
    ]
}