{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Build Tics to Bin (m32)",
            "command": "/usr/bin/g++",
            "args": [
                "-I${workspaceFolder}/Source",
                "-g",
                "-m32",
                "${file}",
                "${workspaceFolder}/Source/Tics.cpp",
                "-o",
                "${workspaceFolder}/Bin/${fileBasenameNoExtension}"
            ],
            "options": {"cwd": "${workspaceFolder}"},
            "problemMatcher": ["$gcc"],
            "group": {"kind": "build", "isDefault": true}
        }
    ]
}